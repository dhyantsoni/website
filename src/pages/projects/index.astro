---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getProjectsSorted } from '../../lib/content';
import { withBase } from '../../lib/links';

const projects = await getProjectsSorted();
---
<Base title="Projects — Dhyan Soni">
  <div class="page-head">
    <div>
      <h1 class="page-title">Projects</h1>
      <p class="page-sub">Things I've designed, built, and shipped.</p>
    </div>
    <a class="browse mono" href={withBase('/tags')}>browse by tag →</a>
  </div>
  {projects.length === 0 && <p class="mono empty">// no projects yet — run `npm run new:project`</p>}
  <div class="grid">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</Base>

<style>
  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .page-title {
    margin: 3rem 0 0.5rem;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
  }
  .page-sub {
    color: var(--text-dim);
    margin: 0 0 2rem;
  }
  .browse {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin-bottom: 2rem;
    white-space: nowrap;
  }
  .browse:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
  }
  .empty {
    color: var(--text-dim);
  }
</style>
