---
import ThemeToggle from './ThemeToggle.astro';
import { withBase } from '../lib/links';

const items = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/projects'), label: 'Projects' },
  { href: withBase('/blog'), label: 'Blog' },
  { href: withBase('/about'), label: 'About' },
];

// Normalize the current path (strip base + trailing slash) to mark the active link.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const current = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
---
<header class="nav">
  <div class="container nav-inner">
    <a class="brand mono" href={withBase('/')}>dhyan<span>.soni</span></a>
    <nav class="nav-links">
      {
        items.map((i) => {
          const path = i.href.replace(base, '').replace(/\/$/, '') || '/';
          const active = path === current;
          return (
            <a href={i.href} aria-current={active ? 'page' : undefined} class={active ? 'active' : ''}>
              {i.label}
            </a>
          );
        })
      }
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .nav {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 10;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.75rem;
  }
  .brand {
    font-weight: 600;
    color: var(--text);
    font-size: 1rem;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand span {
    color: var(--text-dim);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }
  .nav-links a {
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .nav-links a.active {
    color: var(--text);
  }
  @media (max-width: 540px) {
    .brand span {
      display: none;
    }
    .nav-links {
      gap: 0.75rem;
    }
    .nav-links a {
      font-size: 0.9rem;
    }
  }
</style>
